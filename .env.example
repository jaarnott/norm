# ── Core ────────────────────────────────────────────────────────
# Environment: local | testing | staging | production
ENVIRONMENT=local

# Database connection string
DATABASE_URL=postgresql://norm:norm@localhost:5432/norm

# JWT secret for auth tokens — MUST change in production!
JWT_SECRET=dev-secret-change-in-production

# CORS allowed origins (comma-separated). Use "*" for local dev only.
CORS_ALLOWED_ORIGINS=*

# ── Frontend ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── LLM ────────────────────────────────────────────────────────
# Required: Anthropic API key for LLM interpretation and routing
ANTHROPIC_API_KEY=

# Optional: override LLM models
# LLM_INTERPRETER_MODEL=claude-sonnet-4-20250514
# ROUTER_MODEL=claude-haiku-4-5-20251001

# ── Stripe / Billing ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# BILLING_ENFORCEMENT=false

# Stripe price IDs (set per environment)
# STRIPE_PRICE_BASIC=
# STRIPE_PRICE_STANDARD=
# STRIPE_PRICE_MAX=
# STRIPE_PRICE_HR=
# STRIPE_PRICE_PROCUREMENT=
# STRIPE_PRICE_VENUE=

# ── Connectors ─────────────────────────────────────────────────
# BambooHR integration (optional)
BAMBOOHR_SUBDOMAIN=
BAMBOOHR_API_KEY=

# OAuth callback URL (auto-derived from request if not set)
# OAUTH_REDIRECT_URI=

# ── Observability (Phase 4) ────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=console
# SENTRY_DSN=
# GCP_PROJECT_ID=
