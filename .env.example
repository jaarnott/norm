# Database
DATABASE_URL=postgresql://norm:norm@localhost:5432/norm

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Required: Anthropic API key for LLM interpretation and routing
ANTHROPIC_API_KEY=

# Optional: override the LLM model (default: claude-sonnet-4-20250514)
# LLM_INTERPRETER_MODEL=claude-sonnet-4-20250514

# JWT secret for auth tokens (change in production!)
JWT_SECRET=dev-secret-change-in-production

# BambooHR integration (optional -- falls back to mock HR connector)
BAMBOOHR_SUBDOMAIN=
BAMBOOHR_API_KEY=
