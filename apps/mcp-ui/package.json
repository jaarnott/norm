{
  "name": "@norm/mcp-ui",
  "private": true,
  "type": "module",
  "description": "Bundles Norm's real display components into self-contained MCP App HTML.",
  "scripts": {
    "build": "vite build && node scripts/emit.mjs",
    "build:artifact": "vite build --config vite.artifact.config.ts && node scripts/emit-artifact.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
